generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ============================================================
// AUTH (Auth.js v5 / NextAuth)
// ============================================================

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  name          String?
  passwordHash  String?
  role          UserRole  @default(USER)
  image         String?
  emailVerified DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts      Account[]
  sessions      Session[]
  orgMembers    OrgMember[]
  createdOrgs   Org[]     @relation("OrgCreator")
}

enum UserRole {
  USER
  ADMIN
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ============================================================
// ORGANIZATION / WORKSPACE
// ============================================================

model Org {
  id        String      @id @default(cuid())
  name      String
  slug      String      @unique
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  members     OrgMember[]
  projects    Project[]
  usageCounters UsageCounter[]
  createdBy   User        @relation("OrgCreator", fields: [createdById], references: [id])
  createdById String
}

model OrgMember {
  id      String      @id @default(cuid())
  orgId   String
  userId  String
  role    OrgRole     @default(OWNER)
  createdAt DateTime  @default(now())

  org  Org  @relation(fields: [orgId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([orgId, userId])
}

enum OrgRole {
  OWNER
  VIEWER
}

// ============================================================
// PROJECT
// ============================================================

model Project {
  id         String    @id @default(cuid())
  orgId      String
  name       String
  slug       String
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  archivedAt DateTime?

  org          Org              @relation(fields: [orgId], references: [id], onDelete: Cascade)
  tokens       ProjectToken[]
  environments Environment[]
  runs         Run[]
  tests        Test[]
  flakyStats   FlakyTestStat[]
  alerts       Alert[]
  alertEvents  AlertEvent[]

  @@unique([orgId, slug])
}

model ProjectToken {
  id          String    @id @default(cuid())
  projectId   String
  name        String
  tokenHash   String    @unique
  lastUsedAt  DateTime?
  createdAt   DateTime  @default(now())
  revokedAt   DateTime?

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
}

model Environment {
  id        String   @id @default(cuid())
  projectId String
  name      String
  slug      String
  createdAt DateTime @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  runs    Run[]

  @@unique([projectId, slug])
}

// ============================================================
// RUN
// ============================================================

model Run {
  id              String     @id @default(cuid())
  projectId       String
  environmentId   String?
  status          RunStatus  @default(unknown)
  sourceType      String     @default("local") // local | ci
  cliVersion      String?
  branch          String?
  commitSha       String?
  commitMessage   String?
  remoteUrlHash   String?
  startedAt       DateTime?
  finishedAt      DateTime?
  durationMs      Int?
  total           Int        @default(0)
  passed          Int        @default(0)
  failed          Int        @default(0)
  skipped         Int        @default(0)
  timedOut        Int        @default(0)
  retryCount      Int        @default(0)
  createdAt       DateTime   @default(now())

  project     Project       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  environment Environment?  @relation(fields: [environmentId], references: [id])
  testResults TestResult[]
  artifacts   Artifact[]
  alertEvents AlertEvent[]

  @@index([projectId, startedAt(sort: Desc)])
  @@index([projectId, environmentId, startedAt(sort: Desc)])
  @@index([projectId, status, startedAt(sort: Desc)])
}

enum RunStatus {
  passed
  failed
  timed_out
  cancelled
  upload_failed
  unknown
}

// ============================================================
// TESTS
// ============================================================

model Test {
  id                 String   @id @default(cuid())
  projectId          String
  filePath           String
  titlePath          String[]
  browserProjectName String?
  stableKey          String
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  project    Project       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  results    TestResult[]
  flakyStats FlakyTestStat[]

  @@unique([projectId, stableKey])
  @@index([projectId, stableKey])
}

model TestResult {
  id            String      @id @default(cuid())
  runId         String
  testId        String
  status        TestStatus  @default(unknown)
  durationMs    Int         @default(0)
  retryCount    Int         @default(0)
  errorMessage  String?
  errorStack    String?
  stdout        String?
  stderr        String?
  createdAt     DateTime    @default(now())

  run       Run        @relation(fields: [runId], references: [id], onDelete: Cascade)
  test      Test       @relation(fields: [testId], references: [id], onDelete: Cascade)
  artifacts Artifact[]

  @@index([runId, status])
  @@index([testId, createdAt(sort: Desc)])
}

enum TestStatus {
  passed
  failed
  skipped
  timed_out
  interrupted
  flaky
  unknown
}

// ============================================================
// ARTIFACTS
// ============================================================

model Artifact {
  id            String         @id @default(cuid())
  runId         String
  testResultId  String?
  artifactKey   String
  type          ArtifactType
  storageKey    String
  fileName      String
  mimeType      String
  sizeBytes     BigInt         @default(0)
  uploaded      Boolean        @default(false)
  createdAt     DateTime       @default(now())
  expiresAt     DateTime?

  run         Run          @relation(fields: [runId], references: [id], onDelete: Cascade)
  testResult  TestResult?  @relation(fields: [testResultId], references: [id], onDelete: Cascade)

  @@index([runId])
  @@index([testResultId])
}

enum ArtifactType {
  screenshot
  trace
  video
  stdout
  stderr
  attachment
}

// ============================================================
// FLAKINESS
// ============================================================

model FlakyTestStat {
  id               String              @id @default(cuid())
  projectId        String
  testId           String
  windowSize       Int                 @default(20)
  passCount        Int                 @default(0)
  failCount        Int                 @default(0)
  retryPassCount   Int                 @default(0)
  flakeScore       Float               @default(0)
  classification   FlakeClassification @default(stable)
  calculatedAt     DateTime            @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  test    Test    @relation(fields: [testId], references: [id], onDelete: Cascade)

  @@unique([projectId, testId])
  @@index([projectId, flakeScore(sort: Desc)])
}

enum FlakeClassification {
  stable
  watch
  flaky
  regression
}

// ============================================================
// ALERTS
// ============================================================

model Alert {
  id                   String   @id @default(cuid())
  projectId            String
  provider             String   @default("slack")
  enabled              Boolean  @default(false)
  encryptedWebhookUrl  String?
  rules                Json     @default("{\"rules\":[]}")
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  project     Project       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  alertEvents AlertEvent[]

  @@index([projectId])
}

model AlertEvent {
  id         String   @id @default(cuid())
  projectId  String
  runId      String?
  alertId    String?
  dedupeKey  String
  status     String   @default("pending")
  sentAt     DateTime?
  error      String?
  createdAt  DateTime @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  run     Run?    @relation(fields: [runId], references: [id])
  alert   Alert?  @relation(fields: [alertId], references: [id])

  @@index([dedupeKey])
}

// ============================================================
// USAGE
// ============================================================

model UsageCounter {
  id            String   @id @default(cuid())
  orgId         String
  projectId     String?
  month         String   // "2026-06"
  runsCount     Int      @default(0)
  artifactBytes BigInt   @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  org Org @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@unique([orgId, month])
  @@index([orgId, month])
}

// ============================================================
// APP SETTINGS (Admin)
// ============================================================

model AppSetting {
  id    String @id @default(cuid())
  key   String @unique
  value Json
}
